;通用软弱BOSS技能
[common]
[commonend]

;注意物理攻击技能优先级应该比远程技能优先级高
[skill]
0:if(AIS_IsCanSkill(0)=1){AIS_ToSkill(0);AIS_SetTimes(-1);AIS_SetPRI(35);};如果能使用0号技能则释放，次数不限（普通攻击）
1:if(AIS_IsCanSkill(573)=1&AIS_GetHP()<98&AIS_Rand()<30){AIS_ToSkill(573);AIS_SetTimes(-1);AIS_SetPRI(40);};使用573减速能放就放
2:if(AIS_GetAIState()=SATTACK&AIS_IsCanSkill(627)=1&AIS_GetHP()<80&AIS_Rand()<20){AIS_ToSkill(627);AIS_SetTimes(-1);AIS_SetPRI(60);};血少于80%使用627冰天雪地
3:if(AIS_GetAIState()=SATTACK&AIS_IsCanSkill(750)=1&AIS_GetHP()<40&AIS_Rand()<20){AIS_ToSkill(750);AIS_SetTimes(-1);AIS_SetPRI(60);};血少于40%使用750天罚
4:if(AIS_GetAIState()=SATTACK&AIS_GetHP()<20&AIS_IsCanSkill(564)=1)(AIS_ToSkill(564);AIS_SetTimes(1);AIS_SetPRI(34);};血少于30%时对玩家使用麻痹(564)
5:if(AIS_GetAIState()=SATTACK&AIS_Rand()<10&AIS_IsCanSkill(599)=1&AIS_GetHP()<40){AIS_ToSkill(599);AIS_SetTimes(10);AIS_SetPRI(35);};少于10%的情况下释放如梦幻像（599）
6:if(AIS_IsCanSkill(554)=1&AIS_GetHP()<90&AIS_Rand()<50){AIS_ToSkill(554);AIS_SetTimes(-1);AIS_SetPRI(50);};参合指1023能放就放
[skillend]

